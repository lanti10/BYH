generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TRAINER
  CLIENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MessageType {
  TEXT
  PRODUCT_RECOMMENDATION
  PLAN_APPROVAL // scheda creata dal cliente, in attesa di approvazione del trainer
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  BALANCE
  HIIT
}

// Tipo di scheda scelto dal trainer alla creazione
enum PlanType {
  WEIGHTS    // con pesi
  BODYWEIGHT // corpo libero
  SWIMMING   // nuoto
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  avatarUrl String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Trainer-specific
  trainerProfile TrainerProfile?

  // Client-specific
  clientProfile ClientProfile?

  // Messages
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  // Notifiche push (Web Push): un utente può avere più device iscritti
  pushSubscriptions PushSubscription[]
}

// Iscrizione Web Push di un device (browser/PWA) a cui inviare le notifiche.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // chiave pubblica del client (per cifrare il payload)
  auth      String // secret di autenticazione del client
  createdAt DateTime @default(now())

  @@index([userId])
}

model TrainerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio          String?
  specialities String[]
  isActive     Boolean  @default(true)

  // Referral / MLM network
  referralCode   String  @unique @default(cuid())
  referredById   String? // trainer who invited this trainer
  referredBy     TrainerProfile?  @relation("TrainerNetwork", fields: [referredById], references: [id])
  referrals      TrainerProfile[] @relation("TrainerNetwork")
  referralLevel  Int              @default(0)

  // Relations
  clients         ClientProfile[]
  workoutPlans    WorkoutPlan[]
  recommendations ProductRecommendation[]
  productPicks    TrainerProductPick[]
  earnings        TrainerEarning[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientProfile {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id])

  birthDate   DateTime?
  sex         String? // "Uomo" | "Donna"
  height      Float? // cm
  startWeight Float? // kg
  goals       String[]
  trainingDaysPerWeek Int?
  notes       String?
  profileCompleted Boolean @default(false)

  // Relations
  workoutPlans    WorkoutPlan[]
  sessions        WorkoutSession[]
  progressLogs    ProgressLog[]
  orders          Order[]
  recommendations ProductRecommendation[]
  exerciseWeights ExerciseWeightLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── WORKOUTS ─────────────────────────────────────────────────────────────────

model Exercise {
  id          String           @id @default(cuid())
  name        String
  description String?
  videoUrl    String?
  category    ExerciseCategory
  muscles     String[]
  isCustom    Boolean          @default(false)
  createdBy   String? // trainerId if custom

  workoutExercises WorkoutExercise[]

  createdAt DateTime @default(now())
}

model WorkoutPlan {
  id          String @id @default(cuid())
  trainerId   String
  trainer     TrainerProfile @relation(fields: [trainerId], references: [id])
  clientId    String?
  client      ClientProfile?  @relation(fields: [clientId], references: [id])
  isTemplate  Boolean @default(false)

  name          String
  planType      PlanType @default(WEIGHTS)
  description   String?
  durationWeeks Int?
  isActive      Boolean  @default(true)
  startDate     DateTime @default(now())
  endDate       DateTime?

  // Scheda creata dal cliente stesso (non dal trainer).
  createdByClient Boolean @default(false)
  // In attesa di approvazione del trainer: non diventa attiva finché non approva,
  // così non scavalca la scheda assegnata dal trainer.
  pendingApproval Boolean @default(false)

  workouts WorkoutDay[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkoutDay {
  id          String      @id @default(cuid())
  planId      String
  plan        WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  dayOfWeek        Int // indice del giorno di allenamento nella scheda (0-based, per l'ordine)
  scheduledWeekday Int? // giorno della settimana fissato dalla scheda (1=Lun ... 7=Dom); null = non pianificato
  name             String
  durationMin      Int? // durata allenamento in minuti impostata dal trainer; null = usa la stima
  targetCalories   Int? // calorie da bruciare impostate dal trainer; null = obiettivo di default
  notes            String?

  exercises WorkoutExercise[]
  sessions  WorkoutSession[]
}

model WorkoutExercise {
  id           String     @id @default(cuid())
  workoutDayId String
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])

  sets        Int
  reps        String // e.g. "8-12" or "AMRAP"
  weight      Float? // kg consigliati dal trainer (prescrizione: NON viene sovrascritta dal cliente)
  restSeconds Int    @default(60)
  notes       String?
  order       Int    @default(0)

  weightLogs ExerciseWeightLog[]
}

// Peso usato davvero dal cliente su un esercizio della sua scheda.
// È uno storico (una riga per aggiornamento): il peso "attuale" è la riga più recente.
// Resta separato da WorkoutExercise.weight, che è la prescrizione del trainer.
model ExerciseWeightLog {
  id                String          @id @default(cuid())
  clientId          String
  client            ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Sganciato dall'esercizio: se la scheda viene modificata/eliminata il peso NON si
  // perde (SetNull, non Cascade). Lo storico si segue per NOME esercizio, così un
  // "Panca piana" mantiene i suoi pesi anche tra versioni diverse della scheda.
  workoutExerciseId String?
  workoutExercise   WorkoutExercise? @relation(fields: [workoutExerciseId], references: [id], onDelete: SetNull)
  exerciseName      String? // nome esercizio, snapshot al momento del salvataggio (backfill sui vecchi)

  weight    Float // kg
  createdAt DateTime @default(now())

  @@index([clientId, exerciseName, createdAt])
}

model WorkoutSession {
  id           String     @id @default(cuid())
  clientId     String
  client       ClientProfile @relation(fields: [clientId], references: [id])
  // Sganciata dal giorno: se la scheda viene modificata/eliminata la sessione resta
  // (SetNull, non Cascade). Il link serve solo alla progressione finché il giorno esiste.
  workoutDayId String?
  workoutDay   WorkoutDay? @relation(fields: [workoutDayId], references: [id], onDelete: SetNull)
  // Snapshot dell'allenamento svolto: nome giorno, tipo scheda ed esercizi come erano
  // al momento. Così lo storico è autonomo e sopravvive a qualsiasi modifica di scheda.
  snapshot     Json?

  completedAt  DateTime @default(now())
  durationMin  Int?
  durationSec  Int?
  calories     Int?
  avgHeartRate Int?
  maxHeartRate Int?
  notes        String?
  rating       Int? // 1-5

  setLogs SetLog[]
}

model SetLog {
  id        String         @id @default(cuid())
  sessionId String
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  exerciseName String
  setNumber    Int
  reps         Int?
  weight       Float? // kg
  notes        String?
}

// ─── PROGRESS ─────────────────────────────────────────────────────────────────

model ProgressLog {
  id       String        @id @default(cuid())
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id])

  date      DateTime @default(now())
  weight    Float? // kg
  bodyFat   Float? // %
  notes     String?
  photoUrl  String?

  measurements Json? // freeform: { chest, waist, hips, arms, ... }
}

// ─── MESSAGING ────────────────────────────────────────────────────────────────

model Message {
  id         String      @id @default(cuid())
  senderId   String
  sender     User        @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User        @relation("ReceivedMessages", fields: [receiverId], references: [id])
  type       MessageType @default(TEXT)
  content    String
  readAt     DateTime?
  createdAt  DateTime    @default(now())

  // If type is PRODUCT_RECOMMENDATION, link to it
  recommendationId String?
  recommendation   ProductRecommendation? @relation(fields: [recommendationId], references: [id])

  // Se type è PLAN_APPROVAL: la scheda da approvare (il messaggio porta il trainer lì)
  planId String?
  plan   WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  category    String
  ingredients String?

  // Amazon affiliate: link deep del prodotto (con tag affiliato BYH).
  // Il prezzo mostrato è salePrice, sincronizzato da Amazon.
  amazonUrl String?

  // Pricing
  costPrice  Float // from white-label supplier
  salePrice  Float // shown to client

  isActive    Boolean @default(true)
  stock       Int?    // optional, managed by supplier
  supplierSku String? // supplier's SKU for order forwarding

  recommendations ProductRecommendation[]
  orderItems      OrderItem[]
  trainerPicks    TrainerProductPick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Lista "consigliati" curata dal PT: i prodotti che sceglie dal catalogo
// e che i suoi clienti vedono nel segmento "Consigliati dal tuo PT".
// Diverso da ProductRecommendation (che è la condivisione mirata a un cliente).
model TrainerProductPick {
  id        String         @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  note      String?
  createdAt DateTime @default(now())

  @@unique([trainerId, productId])
}

model ProductRecommendation {
  id        String        @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id])
  clientId  String
  client    ClientProfile  @relation(fields: [clientId], references: [id])
  productId String
  product   Product        @relation(fields: [productId], references: [id])

  aiSuggestion    String? // raw AI reasoning
  trainerNote     String? // trainer's personal message
  approvedAt      DateTime? // null = pending trainer approval
  dismissedAt     DateTime?

  messages Message[]

  createdAt DateTime @default(now())
}

// ─── ORDERS ───────────────────────────────────────────────────────────────────

model Order {
  id       String        @id @default(cuid())
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id])

  status          OrderStatus @default(PENDING)
  totalAmount     Float
  supplierOrderId String? // ID returned by white-label supplier
  trackingCode    String?

  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingZip     String
  shippingCountry String @default("IT")

  items     OrderItem[]
  earnings  TrainerEarning[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Float
  costPrice Float
  margin    Float // unitPrice - costPrice
}

// ─── COMMISSIONS ──────────────────────────────────────────────────────────────

model CommissionRule {
  id          String @id @default(cuid())
  level       Int    // 0 = direct seller, 1 = who invited them, 2 = level above, ...
  percentage  Float  // e.g. 15.0 for 15%
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainerEarning {
  id        String         @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id])
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id])

  level      Int   // which MLM level this earning comes from
  percentage Float
  amount     Float
  isPaid     Boolean  @default(false)
  paidAt     DateTime?

  createdAt DateTime @default(now())
}
